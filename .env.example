# Telegram Bot Funnel Configuration Template (Схемный Траф)
# Copy this file to .env and insert your real production values.

# 1. Telegram Bot Token (Obtained from @BotFather)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# 2. Backups and Admin Access
ADMIN_ID=987654321           # Your Telegram User ID to access /admin and /admin_full

# 3. CRM Lead Forwarding (FEATURE 4)
# Group chat ID or Channel ID where Lead alerts are forwarded. Include minus sign (e.g. -100xxxxxxxxxx)
CLOSER_NOTIFY_CHAT_ID=-1002222222222

# 4. Default Verification Channels (Fallback values)
CHANNEL_ID=-1002222222222
CHANNEL_LINK=https://t.me/crypto_inside_channel
CHANNEL_NAME=Crypto Inside 📈

# 5. Google Gemini AI Content Generation
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# 6. Multi-Account Manager System (Telethon API credentials from my.telegram.org)
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=your_api_hash_here

# 7. Sub-Manager Userbot Configurations
MANAGER_1_PHONE=+380000000000

