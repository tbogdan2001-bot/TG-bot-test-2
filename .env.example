# Telegram Bot Funnel Configuration Template
# Copy this file to .env and insert your real values.

# 1. Telegram Connection Configuration
BOT_TOKEN=                  # Your Bot Token from @BotFather (e.g. 12345678:ABCDEF...)
CHANNEL_ID=                 # Target channel ID (e.g. -100123456789 or @username)
CHANNEL_LINK=               # Channel invitation link (e.g. https://t.me/joinchat/...)
CHANNEL_NAME=               # Channel display name (e.g. Crypto Inside 📈)

# 2. Administrative Settings
ADMIN_ID=                   # Your Telegram Account ID for /admin dashboard (e.g. 987654321)
